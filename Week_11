SELECT * FROM UNIVERSITY;
SELECT * FROM DEPARTMENT;
SELECT * FROM PROGRAM;
SELECT * FROM COURSE;
SELECT * FROM SYLLABUS;
SELECT * FROM FACULTY;

SELECT * FROM University
WHERE Location = 'Mumbai';

SELECT P.*
FROM Program P
JOIN Department D ON P.Dept_ID = D.Dept_ID
JOIN University U ON D.University_ID = U.University_ID
WHERE U.Name = 'AMU';

SELECT D.*
FROM Department D
JOIN University U ON D.University_ID = U.University_ID
WHERE U.Name = 'JNU';

SELECT P.*
FROM Program P
JOIN Department D ON P.Dept_ID = D.Dept_ID
JOIN University U ON D.University_ID = U.University_ID
WHERE U.Name = 'University of Jammu';

SELECT DISTINCT U.Name
FROM University U
JOIN Department D ON U.University_ID = D.University_ID
JOIN Program P ON D.Dept_ID = P.Dept_ID
WHERE P.Name = 'MCA';

SELECT C.*
FROM Course C
JOIN Program P ON C.Program_ID = P.Program_ID
JOIN Department D ON P.Dept_ID = D.Dept_ID
JOIN University U ON D.University_ID = U.University_ID
WHERE P.Name = 'MCA' AND U.Name = 'AMU';

SELECT *
FROM Faculty
WHERE Specialization = 'Information Security';

SELECT S.*
FROM Syllabus S
JOIN Course C ON S.Course_ID = C.Course_ID
WHERE C.Name = 'Computer Architecture';

SELECT F.Name, F.Specialization
FROM Faculty F
JOIN Department D ON F.Dept_ID = D.Dept_ID
JOIN University U ON D.University_ID = U.University_ID
WHERE D.Name = 'Computer Science' AND U.Name = 'DU';

SELECT U.Name
FROM University U
JOIN Department D ON U.University_ID = D.University_ID
JOIN Program P ON D.Dept_ID = P.Dept_ID
GROUP BY U.Name
ORDER BY COUNT(P.Program_ID) DESC
FETCH FIRST 1 ROW ONLY;
