CREATE TABLE University (
    University_ID INT PRIMARY KEY,
    Name VARCHAR(100),
    Location VARCHAR(100),
    Ranking INT
);

CREATE TABLE Department (
    Dept_ID INT PRIMARY KEY,
    Name VARCHAR(100),
    Building VARCHAR(50),
    University_ID INT,
    FOREIGN KEY (University_ID) REFERENCES University(University_ID)
);

CREATE TABLE Program (
    Program_ID INT PRIMARY KEY,
    Name VARCHAR(100),
    Duration INT,
    Dept_ID INT,
    FOREIGN KEY (Dept_ID) REFERENCES Department(Dept_ID)
);

CREATE TABLE Course (
    Course_ID INT PRIMARY KEY,
    Name VARCHAR(100),
    Credits INT,
    Program_ID INT,
    FOREIGN KEY (Program_ID) REFERENCES Program(Program_ID)
);

CREATE TABLE Syllabus (
    Syllabus_ID INT PRIMARY KEY,
    Course_ID INT,
    Topics VARCHAR(255),
    Reference_Books VARCHAR(255),
    FOREIGN KEY (Course_ID) REFERENCES Course(Course_ID)
);

CREATE TABLE Faculty (
    Faculty_ID INT PRIMARY KEY,
    Name VARCHAR(100),
    Specialization VARCHAR(100),
    Dept_ID INT,
    FOREIGN KEY (Dept_ID) REFERENCES Department(Dept_ID)
);

CREATE INDEX idx_university_name ON University(Name);
CREATE INDEX idx_department_name ON Department(Name);
CREATE INDEX idx_program_name ON Program(Name);
CREATE INDEX idx_course_name ON Course(Name);
CREATE INDEX idx_faculty_specialization ON Faculty(Specialization);
CREATE INDEX idx_syllabus_course ON Syllabus(Course_ID);

